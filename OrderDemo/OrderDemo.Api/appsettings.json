{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=orderdemo.db"
  },
  "Jwt": {
    "Secret": "*** set via user secrets: Jwt:Secret ***",
    "Issuer": "OrderDemo",
    "Audience": "OrderDemo"
  },
  "Auth0": {
    "Domain": "*** set via user secrets: Auth0:Domain ***",
    "Audience": "*** set via user secrets: Auth0:Audience ***"
  },
  "AdminUser": {
    "Username": "admin",
    "Password": "*** set via user secrets: AdminUser:Password ***"
  },
"Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
